{
  "manifest_version": 2,
  "name": "Easy Browser Ad Blocker",
  "version": "1.0.2",
  "description": "Built-in cosmetic ad filtering for Easy Browser.",
  "browser_specific_settings": {
    "gecko": {
      "id": "easy-adblocker@easybrowser.local"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "exclude_matches": [
        "*://youtube.com/*",
        "*://*.youtube.com/*",
        "*://youtu.be/*",
        "*://*.youtu.be/*"
      ],
      "js": [
        "adblock_cosmetic.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
