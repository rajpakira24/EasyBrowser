<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/group_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/colorSurface"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Colored Group Header -->
        <LinearLayout
            android:id="@+id/group_header"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="4dp">

            <TextView
                android:id="@+id/group_name_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/colorOnPrimary"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="Work Tabs" />

            <TextView
                android:id="@+id/group_count_badge"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginEnd="2dp"
                android:background="@drawable/bg_group_count"
                android:gravity="center"
                android:textColor="@color/colorOnPrimary"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="3" />

            <ImageButton
                android:id="@+id/close_group_btn"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/close_tab"
                android:padding="9dp"
                android:src="@drawable/ic_close" />
        </LinearLayout>

        <!-- Mini 2x2 Grid — Row 1 (always visible) -->
        <LinearLayout
            android:id="@+id/mini_row_1"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal">

            <FrameLayout
                android:id="@+id/cell_0"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <TextView
                    android:id="@+id/cell_0_text"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="2"
                    android:padding="6dp"
                    android:textColor="@color/colorOnSurface"
                    android:textSize="11sp"
                    tools:text="google.com" />
            </FrameLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/colorSurface" />

            <FrameLayout
                android:id="@+id/cell_1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <TextView
                    android:id="@+id/cell_1_text"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="2"
                    android:padding="6dp"
                    android:textColor="@color/colorOnSurface"
                    android:textSize="11sp"
                    tools:text="github.com" />
            </FrameLayout>
        </LinearLayout>

        <!-- Divider between rows (hidden when < 3 tabs) -->
        <View
            android:id="@+id/row_divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/colorSurface" />

        <!-- Mini 2x2 Grid — Row 2 (hidden when < 3 tabs) -->
        <LinearLayout
            android:id="@+id/mini_row_2"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal">

            <FrameLayout
                android:id="@+id/cell_2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <TextView
                    android:id="@+id/cell_2_text"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="2"
                    android:padding="6dp"
                    android:textColor="@color/colorOnSurface"
                    android:textSize="11sp"
                    tools:text="stackoverflow.com" />
            </FrameLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/colorSurface" />

            <!-- Cell 3: normal content OR +N overflow badge -->
            <FrameLayout
                android:id="@+id/cell_3"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <TextView
                    android:id="@+id/cell_3_text"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="2"
                    android:padding="6dp"
                    android:textColor="@color/colorOnSurface"
                    android:textSize="11sp"
                    tools:text="youtube.com" />

                <!-- +N overflow badge (shown when tabs > 4) -->
                <TextView
                    android:id="@+id/plus_badge"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textColor="@color/colorOnPrimary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:text="+5"
                    tools:visibility="visible" />
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
