<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_background">

    <ImageView
        android:id="@+id/home_background_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/app_name"
        android:importantForAccessibility="no"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_home_photo_scrim" />

    <View
        android:id="@+id/home_background_scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_home_photo_scrim"
        android:importantForAccessibility="no" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/home_content_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="28dp"
            android:paddingEnd="16dp"
            android:paddingBottom="194dp">

            <TextView
                android:id="@+id/home_logo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="@string/app_name"
                android:textColor="@color/home_on_image_text"
                android:textSize="31sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="2dp"
                android:alpha="0.72"
                android:text="@string/home_chrome_style_subtitle"
                android:textColor="@color/home_on_image_muted"
                android:textSize="13sp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/privacy_stats_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                app:cardBackgroundColor="@color/home_glass_background"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/home_glass_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="14dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="@string/privacy_stats"
                            android:src="@drawable/ic_security"
                            app:tint="@color/home_accent_mint" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:text="@string/privacy_stats"
                            android:textColor="@color/home_on_image_text"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:baselineAligned="false"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/stat_protected_pages"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/home_accent_mint"
                                android:textSize="21sp"
                                android:textStyle="bold"
                                tools:text="128" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="@string/pages_protected"
                                android:textColor="@color/home_on_image_muted"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/stat_blocked_items"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/home_accent_warm"
                                android:textSize="21sp"
                                android:textStyle="bold"
                                tools:text="42" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="@string/items_blocked"
                                android:textColor="@color/home_on_image_muted"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/stat_time_saved"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/home_accent_blue"
                                android:textSize="21sp"
                                android:textStyle="bold"
                                tools:text="3m" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="@string/time_saved"
                                android:textColor="@color/home_on_image_muted"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/quick_access_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="@string/quick_access"
                android:textColor="@color/home_on_image_text"
                android:textSize="16sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/quick_access_recycler"
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:layout_marginTop="8dp"
                android:clipToPadding="true"
                android:overScrollMode="never"
                tools:listitem="@layout/item_quick_access" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/weather_widget"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="7dp"
        android:layout_marginEnd="12dp"
        android:minWidth="78dp"
        app:cardBackgroundColor="@color/home_glass_background_strong"
        app:cardCornerRadius="18dp"
        app:cardElevation="3dp"
        app:strokeColor="@color/home_glass_border"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="12dp">

            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/weather_icon"
                android:layout_width="21dp"
                android:layout_height="21dp"
                android:alpha="0.96"
                android:contentDescription="@string/weather"
                app:lottie_autoPlay="true"
                app:lottie_loop="true"
                app:lottie_rawRes="@raw/weather_simple_partly_cloudy" />

            <TextView
                android:id="@+id/weather_temperature"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:alpha="0.82"
                android:includeFontPadding="false"
                android:textColor="@color/home_on_image_text"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="27&#176;C" />

            <TextView
                android:id="@+id/weather_location"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:importantForAccessibility="no"
                android:visibility="invisible" />

            <TextView
                android:id="@+id/weather_condition"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:importantForAccessibility="no"
                android:visibility="invisible" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/home_photo_credit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="184dp"
        android:background="@drawable/bg_home_glass_chip"
        android:ellipsize="end"
        android:maxLines="1"
        android:paddingStart="10dp"
        android:paddingTop="5dp"
        android:paddingEnd="10dp"
        android:paddingBottom="5dp"
        android:textColor="@color/home_on_image_text"
        android:textSize="12sp"
        tools:text="Photo by Fabian Quintero" />

    <LinearLayout
        android:id="@+id/home_edge_search_bar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="118dp"
        android:background="@drawable/bg_edge_home_search"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="7dp"
        android:paddingEnd="6dp">

        <ImageButton
            android:id="@+id/btn_security"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_edge_home_search_icon"
            android:contentDescription="@string/search"
            android:padding="10dp"
            android:src="@drawable/ic_search"
            app:tint="@color/edge_search_foreground" />

        <EditText
            android:id="@+id/url_input"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@null"
            android:gravity="center"
            android:hint="@string/search_or_type_url"
            android:imeOptions="actionSearch"
            android:inputType="textUri"
            android:maxLength="2048"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:selectAllOnFocus="true"
            android:singleLine="true"
            android:textColor="@color/edge_search_foreground"
            android:textColorHint="@color/edge_search_hint"
            android:textSize="15sp"
            tools:ignore="Autofill" />

        <ImageButton
            android:id="@+id/btn_clear"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/clear_input"
            android:padding="9dp"
            android:src="@drawable/ic_clear"
            android:visibility="gone"
            app:tint="@color/edge_search_foreground" />

        <ImageButton
            android:id="@+id/btn_search"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/search"
            android:padding="9dp"
            android:src="@drawable/ic_arrow_forward"
            android:visibility="gone"
            app:tint="@color/edge_search_foreground" />

        <ImageButton
            android:id="@+id/btn_mic"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/voice_search"
            android:padding="10dp"
            android:src="@drawable/ic_mic"
            app:tint="@color/edge_search_foreground" />
    </LinearLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_home_bottom_nav"
        android:minHeight="72dp"
        android:paddingTop="2dp"
        android:paddingBottom="4dp"
        app:elevation="0dp"
        app:itemActiveIndicatorStyle="@style/HomeBottomNavigationActiveIndicator"
        app:itemIconTint="@color/home_nav_item_selector"
        app:itemRippleColor="@color/home_search_stroke"
        app:itemTextColor="@color/home_nav_item_selector"
        app:labelVisibilityMode="selected"
        app:menu="@menu/bottom_navigation_menu" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>
