<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/group_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/tab_manager_card"
    app:cardCornerRadius="28dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <View
        android:id="@+id/group_color_border"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/gray" />

    <LinearLayout
        android:id="@+id/group_card_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="5dp"
        android:paddingTop="6dp"
        android:paddingEnd="5dp"
        android:paddingBottom="5dp">

        <LinearLayout
            android:id="@+id/group_info_row"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/header_favicon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/bg_tab_manager_icon_chip"
                android:contentDescription="@string/tab_favicon"
                android:padding="6dp"
                android:src="@drawable/ic_globe"
                android:visibility="gone"
                tools:visibility="visible" />

            <View
                android:id="@+id/group_color_indicator"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_group_count" />

            <LinearLayout
                android:id="@+id/group_text_column"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="9dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tab_count"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textColor="@color/tab_manager_text"
                    android:textSize="16sp"
                    tools:text="5 tabs" />
            </LinearLayout>

            <ImageView
                android:id="@+id/pinned_icon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:contentDescription="@string/pin_tab"
                android:padding="6dp"
                android:src="@drawable/ic_pin"
                android:visibility="gone"
                app:tint="@color/tab_manager_text_secondary"
                tools:visibility="visible" />

            <ImageButton
                android:id="@+id/group_overflow"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/accessibility_more_options"
                android:padding="8dp"
                android:src="@drawable/ic_more_vert"
                app:tint="@color/tab_manager_text" />

            <ImageButton
                android:id="@+id/card_close"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/close_tab"
                android:padding="8dp"
                android:src="@drawable/ic_close"
                android:visibility="gone"
                app:tint="@color/tab_manager_text_secondary"
                tools:visibility="visible" />
        </LinearLayout>

        <GridLayout
            android:id="@+id/preview_grid"
            android:layout_width="match_parent"
            android:layout_height="190dp"
            android:layout_marginTop="4dp"
            android:columnCount="2"
            android:rowCount="2">

            <FrameLayout
                android:id="@+id/preview_cell_1"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:background="@drawable/bg_tab_group_preview_cell_bottom_left"
                android:clipToOutline="true">

                <ImageView
                    android:id="@+id/preview_1"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_tab_thumbnail"
                    android:contentDescription="@string/tab_preview"
                    android:scaleType="centerCrop" />

                <ImageView
                    android:id="@+id/favicon_1"
                    android:layout_width="31dp"
                    android:layout_height="31dp"
                    android:layout_gravity="start|top"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_tab_manager_icon_chip"
                    android:contentDescription="@string/tab_favicon"
                    android:padding="7dp"
                    android:src="@drawable/ic_globe" />

                <TextView
                    android:id="@+id/title_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:background="@color/black_overlay"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:paddingStart="7dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="7dp"
                    android:paddingBottom="4dp"
                    android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                    android:textColor="@color/colorOnPrimary"
                    android:visibility="gone"
                    tools:text="Project dashboard" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/preview_cell_2"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:background="@drawable/bg_tab_group_preview_cell_bottom_right"
                android:clipToOutline="true">

                <ImageView
                    android:id="@+id/preview_2"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_tab_thumbnail"
                    android:contentDescription="@string/tab_preview"
                    android:scaleType="centerCrop" />

                <ImageView
                    android:id="@+id/favicon_2"
                    android:layout_width="31dp"
                    android:layout_height="31dp"
                    android:layout_gravity="start|top"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_tab_manager_icon_chip"
                    android:contentDescription="@string/tab_favicon"
                    android:padding="7dp"
                    android:src="@drawable/ic_globe" />

                <TextView
                    android:id="@+id/title_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:background="@color/black_overlay"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:paddingStart="7dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="7dp"
                    android:paddingBottom="4dp"
                    android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                    android:textColor="@color/colorOnPrimary"
                    android:visibility="gone"
                    tools:text="Release notes" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/preview_cell_3"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:background="@drawable/bg_tab_group_preview_cell"
                android:clipToOutline="true">

                <ImageView
                    android:id="@+id/preview_3"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_tab_thumbnail"
                    android:contentDescription="@string/tab_preview"
                    android:scaleType="centerCrop" />

                <ImageView
                    android:id="@+id/favicon_3"
                    android:layout_width="31dp"
                    android:layout_height="31dp"
                    android:layout_gravity="start|top"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_tab_manager_icon_chip"
                    android:contentDescription="@string/tab_favicon"
                    android:padding="7dp"
                    android:src="@drawable/ic_globe" />

                <TextView
                    android:id="@+id/title_3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:background="@color/black_overlay"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:paddingStart="7dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="7dp"
                    android:paddingBottom="4dp"
                    android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                    android:textColor="@color/colorOnPrimary"
                    android:visibility="gone"
                    tools:text="Inbox" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/preview_cell_4"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:background="@drawable/bg_tab_group_preview_cell"
                android:clipToOutline="true">

                <ImageView
                    android:id="@+id/preview_4"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_tab_thumbnail"
                    android:contentDescription="@string/tab_preview"
                    android:scaleType="centerCrop" />

                <TextView
                    android:id="@+id/more_count"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/black_overlay"
                    android:gravity="center"
                    android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                    android:textColor="@color/tab_manager_text"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:text="+2"
                    tools:visibility="visible" />
            </FrameLayout>
        </GridLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
