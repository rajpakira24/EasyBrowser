<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.EasyBrowser" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryVariant</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorSecondaryVariant">@color/colorSecondaryVariant</item>
        <item name="colorOnSecondary">@color/colorOnSecondary</item>
        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/app_bar_background</item>
        <item name="android:navigationBarColor">@color/browser_chrome_background</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">@bool/is_light_theme</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">@bool/is_light_theme</item>
        <!-- Background colors -->
        <item name="android:windowBackground">@color/backgroundColor</item>
        <item name="colorOnBackground">@color/colorOnBackground</item>
        <item name="android:textColorPrimary">@color/colorOnSurface</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <!-- Surface colors -->
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/colorOnSurface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorOutline">@color/border_color</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.EasyBrowser.RoundedAlertDialog</item>
        <item name="alertDialogTheme">@style/ThemeOverlay.EasyBrowser.RoundedAlertDialog</item>
        <item name="popupMenuStyle">@style/Widget.EasyBrowser.RoundedPopupMenu</item>
        <item name="android:popupMenuStyle">@style/Widget.EasyBrowser.RoundedPopupMenu</item>
        <!-- Enable edge-to-edge display -->
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="p">shortEdges</item>
    </style>
    <style name="Theme.EasyBrowser.GroupOverlay" parent="Theme.EasyBrowser">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.62</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowDisablePreview">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
    <style name="BottomNavigationCompactText" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:includeFontPadding">false</item>
    </style>
    <style name="HomeBottomNavigationActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/home_quick_access_icon_bg</item>
        <item name="android:width">64dp</item>
        <item name="android:height">34dp</item>
    </style>
    <style name="ThemeOverlay.EasyBrowser.RoundedAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="backgroundTint">@color/colorSurface</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay_EasyBrowser_RoundedDialog</item>
    </style>
    <style name="ShapeAppearanceOverlay_EasyBrowser_RoundedDialog">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">26dp</item>
    </style>
    <style name="Widget.EasyBrowser.RoundedPopupMenu" parent="Widget.AppCompat.PopupMenu">
        <item name="android:popupBackground">@drawable/bg_popup_menu_rounded</item>
    </style>
    <style name="SearchPopupAnimation">
        <item name="android:windowEnterAnimation">@anim/search_popup_enter</item>
        <item name="android:windowExitAnimation">@anim/search_popup_exit</item>
    </style>
</resources>
